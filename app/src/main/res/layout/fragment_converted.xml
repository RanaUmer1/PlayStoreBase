<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_color">

    <LinearLayout
        android:id="@+id/tab_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/white"
        android:orientation="horizontal"
        android:paddingTop="16dp"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:id="@+id/tab_pdf"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tv_pdf"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/poppins_semi_bold"
                android:paddingBottom="12dp"
                android:text="@string/pdf_files"
                android:textColor="@color/primary_color"
                android:textSize="16sp" />

            <View
                android:id="@+id/indicator_pdf"
                android:layout_width="40dp"
                android:layout_height="3dp"
                android:layout_marginTop="-3dp"
                android:background="@color/primary_color" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/tab_word"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tv_word"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/poppins_medium"
                android:paddingBottom="12dp"
                android:text="@string/word_files"
                android:textColor="@color/text_color_secondary"
                android:textSize="16sp" />

            <View
                android:id="@+id/indicator_word"
                android:layout_width="40dp"
                android:layout_height="3dp"
                android:layout_marginTop="-3dp"
                android:background="@android:color/transparent" />
        </LinearLayout>

    </LinearLayout>

    <androidx.viewpager2.widget.ViewPager2
        android:id="@+id/viewPager"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tab_container" />

</androidx.constraintlayout.widget.ConstraintLayout>
